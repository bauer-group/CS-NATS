# =============================================================================
# NATS - Environment Configuration
# =============================================================================
# Production-ready 3-node NATS JetStream cluster (RAFT) with operator/JWT auth,
# declarative provisioning, layered client TLS, and Prometheus metrics.
#
# /!\ BEFORE FIRST START — two one-shot, cross-platform steps (Win/Linux/macOS):
#
#   1) python scripts/generate-env.py          # fills CHANGE_ME_* hex secrets
#   2) python scripts/generate-credentials.py  # nsc bootstrap (needs Docker):
#                                               # fills NATS_*_JWT / *_ACCOUNT_*
#
# Step 1 creates .env from this template. Step 2 runs nsc inside natsio/nats-box
# to create the operator + SYS/APP accounts, writes the SECRET .creds to ./creds
# (gitignored) and the PUBLIC JWTs into .env.
#
# Deployment:
#   Development (local build): docker compose -f docker-compose.development.yml up -d --build
#   Cluster (direct ports):    docker compose -f docker-compose.cluster.yml     up -d
#   Coolify:                   configure env in dashboard -> docker-compose.coolify.yml
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================

# Container / volume / network name prefix
STACK_NAME=nats_example_domain_com

# Container timezone (e.g. Europe/Berlin, Etc/UTC)
TIME_ZONE=Etc/UTC


# =============================================================================
# Image Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Production images (pre-built from GHCR) — cluster / coolify
# -----------------------------------------------------------------------------
NATS_IMAGE=ghcr.io/bauer-group/cs-nats/nats
NATS_IMAGE_VERSION=latest

NATS_INIT_IMAGE=ghcr.io/bauer-group/cs-nats/nats-init
NATS_INIT_VERSION=latest

# Upstream sidecar images (used directly, not rebuilt)
NATS_BOX_IMAGE=natsio/nats-box
NATS_BOX_VERSION=latest
NATS_EXPORTER_IMAGE=natsio/prometheus-nats-exporter
NATS_EXPORTER_VERSION=latest

# -----------------------------------------------------------------------------
# Build base (development build) — NATS upstream image the server wraps
# -----------------------------------------------------------------------------
NATS_REPOSITORY=nats
# Floating tag: tracks the latest NATS 2.x on Alpine. Major pinned to avoid a
# breaking jump; the base-image monitor rebuilds when its digest moves. Pin to
# an exact tag (e.g. 2.10.22-alpine) only if you need reproducibility.
NATS_VERSION=2-alpine


# =============================================================================
# Cluster Configuration
# =============================================================================

# Cluster name — MUST be identical on all three nodes.
NATS_CLUSTER_NAME=bauergroup

# Route (node-to-node) authorization. Operator/JWT auth applies to CLIENTS only;
# cluster routes use this simple user/password on the isolated compose network.
NATS_ROUTE_USER=route
# Generate: openssl rand -hex 32  (done by scripts/generate-env.py)
NATS_ROUTE_PASSWORD=CHANGE_ME_ROUTE_PASSWORD


# =============================================================================
# Operator / JWT Credentials  (PUBLIC — filled by generate-credentials.py)
# =============================================================================
# These are PUBLIC JWTs (operator + account assertions; only public keys and
# permission grants — no secrets). They are preloaded by the server (MEMORY
# resolver). The matching SECRET .creds (with private nkey seeds) live in
# ./creds (gitignored). Leave blank — `python scripts/generate-credentials.py`
# fills them in. The server refuses to start while NATS_OPERATOR_JWT is empty.

NATS_OPERATOR_JWT=
NATS_SYS_ACCOUNT_ID=
NATS_SYS_ACCOUNT_JWT=
NATS_APP_ACCOUNT_ID=
NATS_APP_ACCOUNT_JWT=


# =============================================================================
# Sizing Presets  (default = SMALL)
# =============================================================================
# JetStream RAM/disk is driven by STREAMS + CONSUMERS + RETAINED MESSAGES (and
# message size) — not by raw throughput. R3 streams store a full copy on every
# node, so disk per node ~= sum(stream max_bytes). Server-level limits below cap
# the node; account-level limits (set via nsc, see docs/security-and-auth.md)
# cap the APP account — a stream needs headroom in BOTH.
#
#   ╔════════════════╤═════════════╤═══════════╤══════════════╤══════════╤═══════════╤═══════════╗
#   ║ Profile        │ Client conns│ Streams   │ Retained     │ JS_MAX_MEM│ JS_MAX_FILE│ Host RAM ║
#   ╠════════════════╪═════════════╪═══════════╪══════════════╪══════════╪═══════════╪═══════════╣
#   ║ SMALL (default)│ < 500       │ < 50      │ < 10 GB/node │ 1G       │ 10G       │ 2–4 GB    ║
#   ╟════════════════┼─────────────┼───────────┼──────────────┼──────────┼───────────┼───────────╢
#   ║ MEDIUM         │ 500–5 000   │ 50–500    │ < 50 GB/node │ 2G       │ 50G       │ 8–12 GB   ║
#   ╟════════════════┼─────────────┼───────────┼──────────────┼──────────┼───────────┼───────────╢
#   ║ LARGE          │ 5k–50k+     │ 500–5 000 │ < 200 GB/node│ 4G       │ 200G      │ 16–32 GB  ║
#   ╚════════════════╧═════════════╧═══════════╧══════════════╧══════════╧═══════════╧═══════════╝
#
# These are SERVER-level JetStream limits (per node). See docs/sizing-and-tuning.md.

# Max in-memory JetStream store on a node (memory streams). e.g. 1G, 2G, 4G.
NATS_JS_MAX_MEM=1G

# Max on-disk JetStream store on a node (file streams). Scale with the sum of
# stream max_bytes (R3 = a full copy per node). e.g. 10G, 50G, 200G.
NATS_JS_MAX_FILE=10G

# Max size of a single message body. NATS default 1MB, hard ceiling 64MB. Big
# messages buffer in RAM on publish AND deliver — keep large payloads rare and
# prefer an object store / external storage (MinIO). e.g. 1MB, 8MB, 32MB.
NATS_MAX_PAYLOAD=8MB

# Max simultaneous client connections per node (leak guard / DoS bound).
NATS_MAX_CONNECTIONS=65536


# =============================================================================
# TLS / Certificates (client connections on 4222)
# =============================================================================
# Mode (see docs/tls-and-certificates.md):
#   selfsigned  — one shared self-signed cert generated on first boot (default,
#                 zero-config). Race-safe across the 3 nodes; clients trust the CA.
#   byo         — operator-provided cert.pem/key.pem in the certs volume (fail fast)
#   managed     — wait for cert.pem/key.pem written into the certs volume by an
#                 external issuer (cert-manager, acme.sh, a cron); self-signed fallback
# Cluster routes (6222) are ALWAYS plaintext on the isolated network — see the plan.
NATS_TLS_MODE=selfsigned

# Client cert verification: false = server presents a cert, no client certs
# required (no mTLS). true = require + verify client certs (mTLS).
NATS_TLS_VERIFY=false

# Certificate Common Name / SAN (public client hostname). Defaults to localhost.
# Used by the entrypoint when generating the self-signed cert.
# NATS_CLIENT_HOSTNAME=nats.example.domain.com

# Seconds the entrypoint waits for a managed cert before self-signed fallback.
NATS_TLS_MANAGED_WAIT=30


# =============================================================================
# Port Settings (development / cluster — direct host binding)
# =============================================================================
PORT_CLIENT=4222
PORT_CLIENT_2=4223
PORT_CLIENT_3=4224
PORT_MONITOR=8222
PORT_METRICS=7777

# Optional NATS WebSocket (wss for browser clients) — see docs/tls-and-certificates.md
# PORT_WEBSOCKET=8080


# =============================================================================
# External Access  (Model B: client_advertise — direct multi-node failover)
# =============================================================================
# NATS speaks a raw TCP protocol (not HTTP), so there is NO reverse proxy and no
# load balancer in front — the client ports are exposed directly and the client
# library does its own failover across the nodes. For that to work from OUTSIDE
# the Docker network, each node must advertise the PUBLIC address clients use to
# reach it, otherwise the cluster gossips internal (unreachable) addresses.
#
# Set one per node to its public host:port (cluster mode publishes 4222/4223/4224
# on the host). Leave EMPTY for internal-only / localhost dev (no advertise).
# Example (single host, public DNS nats.example.domain.com):
#   NATS_ADVERTISE_NODE1=nats.example.domain.com:4222
#   NATS_ADVERTISE_NODE2=nats.example.domain.com:4223
#   NATS_ADVERTISE_NODE3=nats.example.domain.com:4224
# (Separate hosts per node? Use each node's own host:4222.)
NATS_ADVERTISE_NODE1=
NATS_ADVERTISE_NODE2=
NATS_ADVERTISE_NODE3=


# =============================================================================
# Init Container / Topology Provisioning
# =============================================================================
# The nats-init container provisions JetStream from a JSON topology, idempotently:
#   - development:      repo file config/nats-topology.json (bind-mounted)
#   - cluster/coolify:  the 'nats-config' Docker VOLUME — seeded with the demo on
#                       first boot, then editable at runtime.
# Full reference: docs/messaging-topology.md. ${VAR} values resolve from env.

# Seconds the init polls for the JetStream API (meta-group leader) before giving up.
NATS_WAIT_TIMEOUT=120

# Stream name referenced by config/nats-topology.json (demo).
APP_STREAM_NAME=app-events
