# =============================================================================
# Git Ignore Configuration
# =============================================================================

# Environment (Secrets)
.env
.env.*
.env.bak
!.env.example

# -----------------------------------------------------------------------------
# NATS operator/JWT credentials (SECRET — generated by generate-credentials.py)
# -----------------------------------------------------------------------------
# nsc keystore (operator/account/user nkey SEEDS — private) and exported .creds.
# The PUBLIC operator/account JWTs land in .env (filled by generate-credentials)
# and are not secret, but the seeds and .creds below MUST never be committed.
.nsc/
creds/
*.creds
*.nk

# Generated / mounted certificates
certs/
*.pem
*.key
*.crt

# IDE
.vscode/
.idea/
.claude/
*.code-workspace
.history/

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Logs
*.log
logs/

# Temporary Files
*.tmp
*.temp
*.bak
*~

# Python (nats-init container source)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.venv/
venv/
